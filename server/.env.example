# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/wave_tracker

# express-session secret — use a long random string in production
SESSION_SECRET=your_session_secret_here

# Stormglass API key — https://stormglass.io
STORMGLASS_API_KEY=your_stormglass_api_key_here

# Telegram bot token — create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
